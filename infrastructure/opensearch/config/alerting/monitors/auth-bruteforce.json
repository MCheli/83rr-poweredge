{
  "type": "monitor",
  "monitor_type": "query_level_monitor",
  "name": "auth-bruteforce",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 5,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": [
          "logs-homelab-*"
        ],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                {
                  "term": {
                    "container_name": "nginx"
                  }
                },
                {
                  "term": {
                    "status": 401
                  }
                },
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-5m"
                    }
                  }
                }
              ],
              "must_not": [
                {
                  "prefix": {
                    "path": "/api/"
                  }
                },
                {
                  "prefix": {
                    "path": "/grafana/"
                  }
                },
                {
                  "prefix": {
                    "path": "/_dashboards"
                  }
                },
                {
                  "prefix": {
                    "path": "/-/healthy"
                  }
                },
                {
                  "prefix": {
                    "path": "/-/ready"
                  }
                }
              ]
            }
          },
          "aggs": {
            "by_ip": {
              "terms": {
                "field": "client_ip",
                "size": 5,
                "min_doc_count": 30
              }
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "single-ip-401-burst",
      "severity": "2",
      "condition": {
        "script": {
          "source": "ctx.results[0].aggregations.by_ip.buckets.size() > 0",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "email-mpcheli",
          "destination_id": "cVtg7p0BAgiY_8mBBS8g",
          "message_template": {
            "source": "{\"personalizations\": [{\"to\": [{\"email\": \"mpcheli7@gmail.com\"}]}], \"from\": {\"email\": \"status@markcheli.com\", \"name\": \"Homelab Alerts\"}, \"subject\": \"[homelab] {{ctx.monitor.name}} ({{ctx.results.0.hits.total.value}} events)\", \"content\": [{\"type\": \"text/plain\", \"value\": \"Monitor: {{ctx.monitor.name}}\\nTrigger: {{ctx.trigger.name}} (severity {{ctx.trigger.severity}})\\nEvent count: {{ctx.results.0.hits.total.value}}\\n\\nDashboards: https://logs.ops.markcheli.com/app/dashboards#/view/dash-service-health\\nDiscover: https://logs.ops.markcheli.com/app/discover\"}], \"tracking_settings\": {\"click_tracking\": {\"enable\": false, \"enable_text\": false}, \"open_tracking\": {\"enable\": false}, \"subscription_tracking\": {\"enable\": false}}}",
            "lang": "mustache"
          },
          "throttle_enabled": true,
          "throttle": {
            "value": 30,
            "unit": "MINUTES"
          }
        }
      ]
    }
  ]
}