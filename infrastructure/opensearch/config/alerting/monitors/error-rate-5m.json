{
  "type": "monitor",
  "monitor_type": "query_level_monitor",
  "name": "error-rate-5m",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 5,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": [
          "logs-homelab-*"
        ],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "must": [
                { "terms": { "level": ["ERROR", "CRITICAL", "FATAL"] } },
                { "range": { "@timestamp": { "gte": "now-5m" } } }
              ],
              "must_not": [
                {
                  "bool": {
                    "must": [
                      { "wildcard": { "container_name": "*-db" } },
                      { "match_phrase": { "msg": "no pg_hba.conf entry" } }
                    ]
                  }
                },
                {
                  "bool": {
                    "must": [
                      { "wildcard": { "container_name": "*-db" } },
                      { "match_phrase": { "msg": "password authentication failed" } }
                    ]
                  }
                },
                {
                  "bool": {
                    "must": [
                      { "wildcard": { "container_name": "*-db" } },
                      { "match_phrase": { "msg": "unsupported frontend protocol" } }
                    ]
                  }
                },
                {
                  "bool": {
                    "must": [
                      { "wildcard": { "container_name": "*-db" } },
                      { "match_phrase": { "msg": "no PostgreSQL user name specified" } }
                    ]
                  }
                },
                {
                  "bool": {
                    "must": [
                      { "term": { "container_name": "plex" } },
                      { "match_phrase": { "msg": "Error parsing HTTP request" } }
                    ]
                  }
                }
              ]
            }
          },
          "aggs": {
            "by_service": {
              "terms": { "field": "container_name", "size": 10 },
              "aggs": {
                "top_msg": {
                  "terms": { "field": "msg.keyword", "size": 3 }
                }
              }
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "error-burst",
      "severity": "2",
      "condition": {
        "script": {
          "source": "ctx.results[0].hits.total.value > 10",
          "lang": "painless"
        }
      },
      "actions": [
        {
          "name": "email-mpcheli",
          "destination_id": "cVtg7p0BAgiY_8mBBS8g",
          "message_template": {
            "source": "{\"personalizations\":[{\"to\":[{\"email\":\"mpcheli7@gmail.com\"}]}],\"from\":{\"email\":\"status@markcheli.com\",\"name\":\"Homelab Alerts\"},\"subject\":\"[homelab] error burst: {{ctx.results.0.hits.total.value}} errors in 5 min\",\"content\":[{\"type\":\"text/plain\",\"value\":\"Monitor: {{ctx.monitor.name}} (severity {{ctx.trigger.severity}})\\nWindow: last 5 minutes\\nTotal events: {{ctx.results.0.hits.total.value}}\\n(Excludes known scanner noise: pg_hba/auth-failure on *-db, plex HTTP parse errors.)\\n\\n=== By service ===\\n{{#ctx.results.0.aggregations.by_service.buckets}}\\n[{{key}}] {{doc_count}} event(s)\\n{{#top_msg.buckets}}  - ({{doc_count}}x) {{key}}\\n{{/top_msg.buckets}}\\n{{/ctx.results.0.aggregations.by_service.buckets}}\\n=== Investigate ===\\nDashboard:  https://logs.ops.markcheli.com/app/dashboards#/view/dash-service-health\\nDiscover:   https://logs.ops.markcheli.com/app/discover\\nQuick CLI:  docker compose logs --tail 200 <container_name>\"}],\"tracking_settings\":{\"click_tracking\":{\"enable\":false,\"enable_text\":false},\"open_tracking\":{\"enable\":false},\"subscription_tracking\":{\"enable\":false}}}",
            "lang": "mustache"
          },
          "throttle_enabled": true,
          "throttle": {
            "value": 30,
            "unit": "MINUTES"
          }
        }
      ]
    }
  ]
}
